 "prepared_report": 0,
 "query": "SELECT\n    name AS \"Ticket No:Link/HD Ticket:120\",\n    custom_circuit_id AS \"Circuit ID:Data:120\",\n    customer AS \"Customer:Link/Customer:200\",\n    status AS \"Status:Data:100\",\n\n    CONCAT(\n        SUBSTRING_INDEX(\n            SUBSTRING_INDEX(custom_eta_history,'<br>',2),\n            '<br>',-1\n        ),\n        ' (',\n        TRIM(\n            SUBSTRING_INDEX(\n                SUBSTRING_INDEX(\n                    SUBSTRING_INDEX(custom_eta_history,'eta-meta',2),\n                    '>',-1\n                ),\n                ' \u2022',1\n            )\n        ),\n        ')'\n    ) AS \"Latest ETA:Data:220\",\n\n    CONCAT(\n        SUBSTRING_INDEX(\n            SUBSTRING_INDEX(custom_eta_history,'<br>',5),\n            '<br>',-1\n        ),\n        ' (',\n        TRIM(\n            SUBSTRING_INDEX(\n                SUBSTRING_INDEX(\n                    SUBSTRING_INDEX(custom_eta_history,'eta-meta',3),\n                    '>',-1\n                ),\n                ' \u2022',1\n            )\n        ),\n        ')'\n    ) AS \"Old ETA:Data:220\",\n\n    (\n        LENGTH(custom_eta_history)\n        - LENGTH(REPLACE(custom_eta_history,'eta-entry',''))\n    ) / LENGTH('eta-entry') AS \"Total Count:Int:80\"\n\nFROM `tabHD Ticket`\n\nWHERE custom_eta_history LIKE '%%eta-entry%%'\n\nORDER BY modified DESC",
 "ref_doctype": "HD Ticket",
 "report_name": "ETA Report",
 "report_type": "Query Report",
